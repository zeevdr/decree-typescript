{
  "name": "@opendecree/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for OpenDecree — schema-driven configuration management (alpha)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "generate": "rm -rf src/generated && buf generate",
    "build": "tsc",
    "lint": "biome check src/ test/",
    "format": "biome format --write src/ test/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "config",
    "configuration",
    "decree",
    "grpc",
    "schema",
    "management"
  ],
  "author": "Zeev Dreifuss",
  "license": "Apache-2.0",
  "homepage": "https://github.com/zeevdr/decree-typescript",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeevdr/decree-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/zeevdr/decree-typescript/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@vitest/coverage-v8": "^3.1.0",
    "ts-proto": "^2.11.6",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
